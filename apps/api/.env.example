# APP Config
PORT=3000
NODE_ENV=production
APP_NAME="ZapScore API"
APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/zapscore?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# API-Football
API_FOOTBALL_KEY=your_api_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Default Targets
DEFAULT_LEAGUE_ID=71
DEFAULT_SEASON=2026
