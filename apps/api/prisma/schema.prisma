generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model League {
  id         String   @id @default(uuid())
  externalId Int      @unique
  name       String
  country    String?
  logo       String?
  type       String?
  season     Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  fixtures   Fixture[]
  standings  Standing[]

  @@index([externalId])
}

model Team {
  id         String   @id @default(uuid())
  externalId Int      @unique
  name       String
  code       String?
  country    String?
  logo       String?
  founded    Int?
  national   Boolean? @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  homeFixtures Fixture[] @relation("HomeTeam")
  awayFixtures Fixture[] @relation("AwayTeam")
  standings    Standing[]

  @@index([externalId])
}

model Fixture {
  id          String   @id @default(uuid())
  externalId  Int      @unique
  leagueId    String
  season      Int
  date        DateTime
  round       String?
  statusLong  String?
  statusShort String?
  elapsed     Int?
  venueName   String?
  venueCity   String?
  homeTeamId  String
  awayTeamId  String
  homeGoals   Int?
  awayGoals   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  league      League @relation(fields: [leagueId], references: [id])
  homeTeam    Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  // Relações para dados técnicos
  events      FixtureEvent[]
  stats       FixtureStat[]
  lineups     FixtureLineup[]

  @@index([externalId])
  @@index([date])
}

model FixtureEvent {
  id        String   @id @default(uuid())
  fixtureId String
  time      Int
  teamId    Int
  player    String?
  assist    String?
  type      String   // Goal, Card, Subst, Var
  detail    String?
  createdAt DateTime @default(now())

  fixture   Fixture  @relation(fields: [fixtureId], references: [id])
}

model FixtureStat {
  id        String   @id @default(uuid())
  fixtureId String
  teamId    Int
  type      String   // Shots on Goal, Possession, Corners, Fouls...
  value     String?
  createdAt DateTime @default(now())

  fixture   Fixture  @relation(fields: [fixtureId], references: [id])

  @@unique([fixtureId, teamId, type])
}

model FixtureLineup {
  id        String   @id @default(uuid())
  fixtureId String
  teamId    Int
  player    String
  number    Int?
  pos       String?  // G, D, M, F
  grid      String?  // Posição no campo (ex: 1:1)
  isStart   Boolean  @default(true)
  createdAt DateTime @default(now())

  fixture   Fixture  @relation(fields: [fixtureId], references: [id])
}

model Standing {
  id          String   @id @default(uuid())
  leagueId    String
  teamId      String
  season      Int
  rank        Int
  points      Int
  goalsDiff   Int
  played      Int
  win         Int
  draw        Int
  lose        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  league      League @relation(fields: [leagueId], references: [id])
  team        Team   @relation(fields: [teamId], references: [id])

  @@unique([leagueId, teamId, season])
}
